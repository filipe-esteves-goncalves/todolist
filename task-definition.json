{
  "family": "todo-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "todo-app",
      "image": "ghcr.io/filipe1986/todolist:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        },
        {
          "containerPort": 8081,
          "hostPort": 8081,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_HOST", "value": "postgres" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_USER", "value": "myuser" },
        { "name": "DB_PASSWORD", "value": "secret" },
        { "name": "DB_NAME", "value": "mydatabase" }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512"
}

